# ---- HTTP server ----
# HTTP port (exposed publicly)
PORT=8080

# ---- Whapi ----
# Bearer token for Whapi (secret)
WHAPI_TOKEN=
# Whapi gate base URL
WHAPI_BASE_URL=https://gate.whapi.cloud

# ---- OpenAI ----
# OpenAI auth (secret)
OPENAI_API_KEY=
# structuring + answering + acknowledge/follow-up
OPENAI_CHAT_MODEL=gpt-4o
# intent extraction + REPORT/QUERY classification
OPENAI_CLASSIFY_MODEL=gpt-4o-mini

# ---- Database ----
# Supabase Postgres (append ?sslmode=require if needed) (secret)
DATABASE_URL=

# ---- Webhook security ----
# Secret path segment for the webhook route (random hex)
WEBHOOK_SECRET=

# ---- Reminder scheduling (runtime values live in the `settings` table) ----
# Timezone for evaluating reminder start/interval/stop (does NOT affect data/day semantics)
REMINDER_TZ=Asia/Kolkata
# Default first-reminder time (seeds settings.reminder_start; runtime-tunable)
REMINDER_START=17:00
# Default repeat interval minutes (seeds settings.reminder_interval_min; runtime-tunable)
REMINDER_INTERVAL_MIN=15
# Default end-of-day cutoff (seeds settings.reminder_stop; runtime-tunable)
REMINDER_STOP=22:00

# ---- Report / follow-up behaviour ----
# How many recent reports feed the acknowledge/follow-up LLM call
RECENT_REPORTS_FOR_FOLLOWUP=5

# ---- Project matching ----
# pg_trgm similarity cutoff for project matching
PROJECT_MATCH_THRESHOLD=0.45

# ---- Media guard ----
# media size guard in bytes (~25MB, OpenAI limit)
MAX_MEDIA_BYTES=26214400

# ---- Deep link / docs ----
# Bot's WhatsApp number (intl digits, no +); docs only, used to build the wa.me deep link
BOT_NUMBER=

# ---- Seed (optional demo CEO root) ----
# Optional bootstrap of root user
SEED_CEO_PHONE=
SEED_CEO_NAME=Gopal Narang
